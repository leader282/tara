# Supabase Edge Functions environment variables (notification workers)
# Never commit real secret values.

# Supabase project URL for server-to-server calls.
SUPABASE_URL=http://127.0.0.1:54321

# Service role key used only inside Edge Functions.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional fallback key name if your environment uses this variable name.
# SUPABASE_SECRET_KEY=your-supabase-secret-key

# Shared secret for service-to-service invocation.
# Requests must include either:
# - x-cron-secret: <value>
# - Authorization: Bearer <value>
CRON_SECRET=replace-with-long-random-secret

# Optional alternate secret variable name supported by the functions.
# EDGE_FUNCTION_SECRET=replace-with-long-random-secret

# Optional: Expo access token (only needed if your Expo project requires it).
EXPO_ACCESS_TOKEN=optional-expo-access-token
