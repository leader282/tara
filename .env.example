EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id
EXPO_PUBLIC_APP_ENV=development

# Optional: set to enable Sentry event ingestion from app builds.
EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Build-time Sentry upload values belong in EAS/CI secrets, not local app env files.
# Do not place SENTRY_AUTH_TOKEN, SENTRY_ORG, or SENTRY_PROJECT in `.env`.
