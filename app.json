{
  "expo": {
    "name": "Tara",
    "slug": "tara",
    "version": "1.0.0",
    "scheme": "tara",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "predictiveBackGestureEnabled": false
    }
  }
}
